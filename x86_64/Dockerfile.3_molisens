# syntax=docker/dockerfile:1.2
ARG DOCKER_BASE
FROM $DOCKER_BASE      

SHELL ["/bin/bash", "-o", "pipefail", "-c"]



# Install vifware.aap
RUN bash -c 'git config --global credential.helper cache'

#RUN --mount=type=secret,id=deploytoken bash -c 'git config --global credential.helper cache && \
